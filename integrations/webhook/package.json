{
  "name": "@open-wa/integration-webhook",
  "version": "5.0.0-alpha.3",
  "description": "Webhook delivery integration plugin for open-wa",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "dev": "tsdown src/index.ts --format esm --dts --watch",
    "lint": "oxlint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@open-wa/plugin-sdk": "workspace:*",
    "p-queue": "^8.0.0"
  },
  "devDependencies": {
    "@open-wa/logger": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
