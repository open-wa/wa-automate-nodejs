{
  "name": "@open-wa/integration-cloudflare",
  "version": "5.0.0-alpha.1",
  "description": "Cloudflare Tunnel integration plugin for open-wa",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-wa/core": "workspace:*",
    "@open-wa/logger": "workspace:*",
    "cloudflared": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
