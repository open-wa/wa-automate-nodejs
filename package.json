{
  "name": "@open-wa/monorepo",
  "version": "5.0.0-alpha.1",
  "private": true,
  "description": "The most reliable WhatsApp automation library - v5 Monorepo",
  "license": "Apache-2.0",
  "author": "Mohammed Shah <@smashah>",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-wa/wa-automate-nodejs.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "integrations/*",
    "sdks/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/socket.io": "catalog:",
    "prettier": "catalog:",
    "syncpack": "^11.0.0",
    "turbo": "^1.10.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.21.1",
    "pnpm": ">=10.25.0"
  },
  "packageManager": "pnpm@10.26.1",
  "dependencies": {
    "@elastic/elasticsearch": "catalog:"
  }
}