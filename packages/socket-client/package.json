{
  "name": "@open-wa/socket-client",
  "version": "5.0.0-alpha.0",
  "description": "Easily connect to remote instances of the EASY API",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm",
    "dev": "tsdown src/index.ts --format cjs,esm --watch",
    "lint": "oxlint src test",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run test/SocketClient.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-wa/wa-automate-socket-client-nodejs.git"
  },
  "keywords": [
    "wa-automate",
    "easy-api",
    "remote",
    "socket"
  ],
  "author": "Mohammed Shah <@smashah>",
  "publishConfig": {
    "access": "public"
  },
  "license": "H-DNH V1.0",
  "bugs": {
    "url": "https://github.com/open-wa/wa-automate-socket-client-nodejs/issues"
  },
  "homepage": "https://github.com/open-wa/wa-automate-socket-client-nodejs#readme",
  "dependencies": {
    "@open-wa/wa-automate-types-only": "workspace:*",
    "debug": "^4.3.4",
    "eventsource": "^3.0.7",
    "eventemitter2": "^6.4.9",
    "isomorphic-ws": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "type": "module"
}
