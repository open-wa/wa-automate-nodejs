{
  "name": "@open-wa/orchestrator",
  "version": "1.9.10",
  "description": "An example of how to orchestrate @open-wa/wa-automate npx cli using pm2",
  "main": "./dist/index.js",
  "bin": {
    "orch": "./bin/orch",
    "owaupdate": "cross-env PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm i --save @open-wa/wa-automate@latest",
    "opm2": "./bin/opm2"
  },
  "scripts": {
    "preinstall": "cross-env NPM_CONFIG_PUPPETEER_SKIP_DOWNLOAD=true PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true",
    "build": "rimraf ./dist && rimraf ./dist-obf && tsc",
    "build:prod": "npm run build && npm run obf",
    "obf": "rimraf ./dist-obf && javascript-obfuscator ./dist --output ./dist-obf",
    "start": "NODE_ENV=prod ./pm2  start ./dist/index.js --name admin -- --trace-warnings",
    "start:docker": "NODE_ENV=prod ./pm2r  start ./dist/index.js --name admin -- --trace-warnings",
    "start:dev": "NODE_ENV=dev PORT=3000 ./pm2 start ./dist/index.js --name admin",
    "monit": "./pm2 monit",
    "watch": "tsc -w",
    "patch": "npm version patch",
    "superdev": "concurrently \"npm run watch\" \"npm run nodemon\"",
    "nodemon": "nodemon --watch dist --exec npm run dev",
    "logs": " ./pm2 logs admin",
    "dev": "npm run build && npm run purge && npm run start:dev",
    "upd": "cross-env PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true yarn add @open-wa/wa-automate@latest",
    "fire": "npx @open-wa/wa-automate",
    "purge": "./pm2 delete all && ./pm2 flush",
    "docker:build:run": "npm run build:prod && docker build --platform=linux/amd64  -t wa-orch-test . && docker run -d --init -p 3000:3000 wa-orch-test"
  },
  "author": "SMASHAH <shah@idk.uno> (https://smashah.dev)",
  "license": "ISC",
  "dependencies": {
    "@open-wa/wa-automate": "*",
    "ansi-colors": "^4.1.3",
    "api-key-auth": "^0.2.3",
    "axe": "^11.0.2",
    "axios": "^1.4.0",
    "cabin": "^11.0.3",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.3",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "express-request-id": "1.4.1",
    "firebase": "^9.14.0",
    "fs-extra": "^10.1.0",
    "get-port": "^5.1.1",
    "helmet": "^6.0.0",
    "http-proxy-middleware": "^2.0.6",
    "human-id": "^3.0.0",
    "is-url-superb": "^6.1.0",
    "javascript-obfuscator": "^4.0.0",
    "json5": "^2.2.1",
    "keygenerator": "^1.0.4",
    "klona": "^2.0.5",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "node-machine-id": "^1.1.12",
    "os-name": "^5.0.1",
    "p-queue": "6.6.2",
    "patch-package": "^6.4.7",
    "pico-s3": "^2.1.0",
    "ping": "^0.4.2",
    "pm2": "^5.3.0",
    "public-ip": "4.0.4",
    "request-received": "^0.0.3",
    "response-time": "^2.3.2",
    "swagger-ui-dist": "^4.10.3",
    "traverse": "^0.6.6",
    "uuid": "^9.0.0",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1",
    "winston-papertrail": "^1.0.5",
    "winston-syslog": "^2.7.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.2",
    "@types/express": "^4.17.14",
    "@types/express-http-proxy": "^1.6.3",
    "@types/morgan": "^1.9.3",
    "@types/traverse": "^0.6.32",
    "@types/uuid": "^8.3.4",
    "@types/winston-syslog": "^2.4.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "ava": "^5.1.0",
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.12.0",
    "javascript-obfuscator": "^4.0.0",
    "nodemon": "^2.0.20",
    "npm-cli-login": "^1.0.0",
    "rimraf": "^3.0.2",
    "typescript": "^5.2.0"
  },
  "overrides": {
    "pm2": {
      "eventemitter2": "6.4.9"
    }
  },
  "publishConfig": {
    "registry": "https://registry.openwa.cloud"
  }
}
