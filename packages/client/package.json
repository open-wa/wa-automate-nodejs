{
  "name": "@open-wa/client",
  "version": "5.0.0-alpha.1",
  "description": "User-facing API client for open-wa WhatsApp automation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --format cjs",
    "dev": "tsdown src/index.ts --format esm --format cjs --watch",
    "test": "vitest run",
    "lint": "oxlint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-wa/wa-decrypt": "workspace:*",
    "@open-wa/core": "workspace:*",
    "@open-wa/domain": "workspace:*",
    "@open-wa/hyperemitter": "workspace:*",
    "@open-wa/logger": "workspace:*",
    "@open-wa/schema": "workspace:*",
    "axios": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
