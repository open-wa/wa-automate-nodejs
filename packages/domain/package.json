{
  "name": "@open-wa/domain",
  "version": "5.0.0-alpha.0",
  "description": "Domain data structures for open-wa WhatsApp automation (Collectors, etc.)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs",
    "dev": "tsdown src/index.ts --format cjs --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@open-wa/hyperemitter": "workspace:*",
    "@open-wa/schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-wa/wa-automate-nodejs.git"
  }
}
