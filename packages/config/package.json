{
  "name": "@open-wa/config",
  "version": "5.0.0-alpha.1",
  "description": "Configuration management for open-wa - schemas, loading, merging, and validation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    }
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "generate:schema": "ts-node scripts/generate-json-schema.ts"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "cosmiconfig-typescript-loader": "^6.0.0",
    "deepmerge-ts": "^7.1.3",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.22.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "open-wa",
    "whatsapp",
    "config",
    "configuration",
    "zod",
    "cosmiconfig"
  ]
}
