{
  "name": "@open-wa/config",
  "version": "5.0.0-alpha.5",
  "description": "Configuration management for open-wa - schemas, loading, merging, and validation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs",
      "require": "./dist/schema.cjs"
    }
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src scripts",
    "typecheck": "tsc --noEmit",
    "generate:schema": "tsx scripts/generate-json-schema.ts"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.0",
    "cosmiconfig-typescript-loader": "^6.0.0",
    "deepmerge-ts": "^7.1.3",
    "zod": "catalog:",
    "zod-to-json-schema": "^3.22.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "open-wa",
    "whatsapp",
    "config",
    "configuration",
    "zod",
    "cosmiconfig"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/open-wa/wa-automate-nodejs.git"
  }
}
