{
    "name": "@open-wa/schema",
    "version": "5.0.0-alpha.1",
    "description": "Zod-based schema definitions for open-wa",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.js",
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./generated": {
            "require": "./dist/generated/index.js",
            "import": "./dist/generated/index.js",
            "types": "./dist/generated/index.d.ts"
        },
        "./implementor": {
            "require": "./dist/implementor.js",
            "import": "./dist/implementor.js",
            "types": "./dist/implementor.d.ts"
        },
        "./methods": {
            "require": "./dist/methods/index.js",
            "import": "./dist/methods/index.js",
            "types": "./dist/methods/index.d.ts"
        }
    },
    "scripts": {
        "generate": "ts-node scripts/gen-types.ts && ts-node scripts/gen-client-implementation.ts",
        "build": "pnpm generate && tsc && tsc --project tsconfig.generated.json",
        "dev": "tsc --watch",
        "lint": "eslint src --ext .ts",
        "test": "jest",
        "test:contracts": "jest --testMatch='**/*.contract.test.ts'",
        "verify": "ts-node scripts/verify-v5-pipeline.ts",
        "ci": "pnpm verify && pnpm test:contracts && pnpm build"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^6.4.0",
        "@open-wa/config": "workspace:*",
        "@open-wa/legacy": "workspace:*",
        "@open-wa/utils": "workspace:*",
        "zod": "catalog:",
        "zod-to-json-schema": "^3.22.3"
    },
    "devDependencies": {
        "@types/jest": "catalog:",
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "ts-node": "catalog:",
        "typescript": "catalog:",
        "zod-to-ts": "^1.2.0"
    },
    "publishConfig": {
        "access": "public"
    }
}