{
  "name": "@open-wa/hyperemitter",
  "version": "5.0.0-alpha.5",
  "description": "HyperEmitter: high-performance, schema-driven event emitter for the open-wa v5 stack.",
  "main": "dist/index.cjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs",
    "dev": "tsdown src/index.ts --format cjs --watch",
    "lint": "oxlint src",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "bench:baseline": "node benchmarks/baseline/run-baseline.js",
    "bench:baseline:ci": "node benchmarks/baseline/run-baseline.js --ci"
  },
  "keywords": [
    "eventemitter",
    "events",
    "pubsub",
    "hyperemitter",
    "open-wa"
  ],
  "author": "open-wa",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@open-wa/logger": "workspace:*"
  },
  "devDependencies": {
    "emittery": "^1.0.1",
    "eventemitter2": "^6.4.9",
    "eventemitter3": "^5.0.1",
    "mitt": "^3.0.1",
    "tseep": "^1.0.1",
    "typescript": "catalog:"
  }
}
