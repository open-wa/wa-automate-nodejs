{
  "name": "@open-wa/core",
  "version": "5.0.0-alpha.1",
  "description": "Core orchestration backbone for open-wa WhatsApp automation",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-wa/config": "workspace:*",
    "@open-wa/driver-interface": "workspace:*",
    "@open-wa/hyperemitter": "workspace:*",
    "@open-wa/logger": "workspace:*",
    "@open-wa/schema": "workspace:*",
    "p-queue": "6.6.2",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/uuid": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@open-wa/driver-puppeteer": "workspace:*",
    "@open-wa/driver-playwright": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@open-wa/driver-puppeteer": {
      "optional": true
    },
    "@open-wa/driver-playwright": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
