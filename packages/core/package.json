{
  "name": "@open-wa/core",
  "version": "5.0.0-alpha.2",
  "description": "Core orchestration backbone for open-wa WhatsApp automation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --format cjs && node scripts/copy-launch-script.mjs",
    "dev": "tsdown src/index.ts --format esm --format cjs --watch",
    "test": "vitest run",
    "lint": "oxlint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@open-wa/config": "workspace:*",
    "@open-wa/driver-interface": "workspace:*",
    "@open-wa/hyperemitter": "workspace:*",
    "@open-wa/logger": "workspace:*",
    "@open-wa/plugin-sdk": "workspace:*",
    "@open-wa/schema": "workspace:*",
    "hono": "catalog:",
    "p-queue": "6.6.2",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@open-wa/driver-puppeteer": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@open-wa/driver-puppeteer": "workspace:*",
    "@open-wa/driver-playwright": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@open-wa/driver-puppeteer": {
      "optional": true
    },
    "@open-wa/driver-playwright": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-wa/wa-automate-nodejs.git"
  }
}
