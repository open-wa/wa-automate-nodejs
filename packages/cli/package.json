{
  "name": "@open-wa/cli",
  "version": "5.0.0-alpha.3",
  "description": "CLI for @open-wa WhatsApp automation - Easy API mode",
  "main": "./dist/index.cjs",
  "module": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "wa": "./dist/bin.cjs",
    "wa-automate": "./dist/bin.cjs",
    "openwa": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/bin.ts --format cjs",
    "dev": "tsdown src/index.ts src/bin.ts --format cjs --watch",
    "start": "node dist/bin.cjs",
    "test": "vitest run",
    "lint": "oxlint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@open-wa/core": "workspace:*",
    "@open-wa/wa-automate": "workspace:*",
    "ink": "^5.2.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "ws": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "^18.3.12",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-wa/wa-automate-nodejs.git"
  }
}
