{
  "name": "@open-wa/cli",
  "version": "5.0.0-alpha.1",
  "description": "CLI for @open-wa WhatsApp automation - Easy API mode",
  "main": "./dist/index.cjs",
  "module": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "wa": "./dist/bin.cjs",
    "wa-automate": "./dist/bin.cjs",
    "openwa": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/bin.ts --format cjs",
    "dev": "tsdown src/index.ts src/bin.ts --format cjs --watch",
    "start": "node dist/bin.cjs",
    "test": "vitest run",
    "lint": "oxlint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-wa/wa-automate": "workspace:*",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
