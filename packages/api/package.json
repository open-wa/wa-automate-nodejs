{
  "name": "@open-wa/api",
  "version": "5.0.0-alpha.1",
  "description": "Reusable Easy API transport and runtime explorer layer for open-wa",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.cjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.cts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs",
    "dev": "tsdown src/index.ts --format cjs --watch",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@elastic/elasticsearch": "catalog:",
    "@hono/node-server": "catalog:",
    "@hono/node-ws": "^1.3.0",
    "@open-wa/screencaster": "workspace:*",
    "@open-wa/schema": "workspace:*",
    "hono": "catalog:",
    "socket.io": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
