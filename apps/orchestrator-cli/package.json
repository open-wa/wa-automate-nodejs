{
    "name": "@open-wa/orchestrator-cli",
    "version": "5.0.0-alpha.1",
    "private": true,
    "description": "Multi-session orchestration CLI",
    "bin": {
        "wa-orch": "./dist/index.cjs",
        "orch": "./bin/orch",
        "opm2": "./bin/opm2"
    },
    "scripts": {
        "build": "tsdown src/index.ts --format cjs",
        "dev": "tsdown src/index.ts --format cjs --watch",
        "lint": "oxlint src",
        "start": "node dist/index.cjs"
    },
    "dependencies": {
        "@open-wa/orchestrator": "workspace:*",
        "@open-wa/legacy": "workspace:*",
        "hono": "catalog:",
        "@hono/node-server": "catalog:",
        "express": "catalog:",
        "dotenv": "catalog:",
        "pm2": "catalog:",
        "cors": "catalog:",
        "helmet": "catalog:",
        "morgan": "catalog:",
        "cabin": "catalog:",
        "axe": "catalog:",
        "public-ip": "catalog:",
        "response-time": "catalog:",
        "request-received": "catalog:",
        "express-request-id": "catalog:"
    },
    "devDependencies": {
        "typescript": "catalog:",
        "@types/node": "catalog:",
        "@types/express": "catalog:"
    }
}
