    "lint": "oxlint src scripts",
    "workspace-docs": "node scripts/gen-workspace-readme-docs.js",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,md,mdx}\" \"scripts/**/*.{ts,js}\"",
    "copy": "node scripts/copy-openapi.js",
    "openapi": "node scripts/copy-openapi.js",
    "check:mascots": "node scripts/check-mascot-assets.js",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "test:og": "tsx scripts/test-og.ts"
  },
