{
  "name": "docs",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "predev": "pnpm openapi",
    "prebuild": "pnpm openapi",
    "dev": "vite dev",
    "build": "pnpm workspace-docs && vite build",
    "start": "serve dist/client",
    "types": "pnpm workspace-docs && fumadocs-mdx && tsc --noEmit",
