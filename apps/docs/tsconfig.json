{
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ],
        "types": [
            "vite/client"
        ],
        "isolatedModules": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "target": "ES2022",
        "allowJs": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "fumadocs-mdx:collections/*": [
                "./.source/*"
            ]
        },
        "noEmit": true
    }
}