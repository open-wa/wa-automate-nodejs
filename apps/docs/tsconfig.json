{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "moduleResolution": "bundler"
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".source.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}